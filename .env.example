# ===========================
# Gmail SMTP Configuration
# ===========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password
SMTP_FROM_NAME=Your Name

# ===========================
# SendGrid SMTP Configuration
# ===========================
SENDGRID_SMTP_HOST=smtp.sendgrid.net
SENDGRID_SMTP_PORT=587
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM=your_email@example.com
SENDGRID_FROM_NAME=Your Name
SENDGRID_SANDBOX=false

# ===========================
# Amazon SES SMTP Configuration
# ===========================
SES_SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USERNAME=your_ses_smtp_username
SES_SMTP_PASSWORD=your_ses_smtp_password
SES_FROM=your_email@example.com
SES_FROM_NAME=Your Name

# ===========================
# Mailgun SMTP Configuration
# ===========================
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_PORT=587
MAILGUN_SMTP_USERNAME=your_mailgun_sandbox_email@example.com
MAILGUN_SMTP_PASSWORD=your_mailgun_smtp_password
MAILGUN_FROM=Your Name <your_mailgun_sandbox_email@example.com>
