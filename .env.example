# SMTP Email Configuration for Sending Emails

# The hostname of your SMTP mail server (e.g., Gmail, Outlook, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com

# The port used for sending emails.
# 587 = TLS (recommended), 465 = SSL, 25 = non-secure (not recommended)
SMTP_PORT=587

# Your SMTP username (usually your email address)
SMTP_USERNAME=your_email@example.com

# Your SMTP password or app-specific password (DO NOT use your actual email password for Gmail)
SMTP_PASSWORD=your_app_password

# The name that will appear in the "From" field when the email is sent
SMTP_FROM_NAME=Your Name